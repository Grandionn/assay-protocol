# ─── Deployer ──────────────────────────────────────────────────────────────────
# Private key of the deployer wallet (no 0x prefix)
PRIVATE_KEY=your_private_key_here

# ─── RPC Endpoints ─────────────────────────────────────────────────────────────
# Base Sepolia testnet (defaults to public RPC if not set)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base mainnet (defaults to public RPC if not set)
BASE_RPC_URL=https://mainnet.base.org

# ─── Basescan Verification ─────────────────────────────────────────────────────
# Get your API key from https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here

# ─── Optional ──────────────────────────────────────────────────────────────────
# Set to "true" to enable gas reporting during tests
REPORT_GAS=false
